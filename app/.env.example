PORT=8080
MEDIA_DROP_BIND_HOST=127.0.0.1
MEDIA_DROP_ADMIN_PASSWORD=change-me
MEDIA_DROP_STORAGE_ROOT=/srv/media-drop
MEDIA_DROP_DB_PATH=/srv/media-drop/db/media-drop.sqlite
MEDIA_DROP_MAX_CONCURRENT=2
MEDIA_DROP_MAX_FILE_SIZE_BYTES=21474836480
MEDIA_DROP_ALLOW_PRIVATE_HOSTS=false
MEDIA_DROP_ALLOWED_DOMAINS=
MEDIA_DROP_HTTP_BASE_URL=https://media.p3lending.space
MEDIA_DROP_YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
MEDIA_DROP_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
MEDIA_DROP_ARIA2C_PATH=/usr/bin/aria2c

# Retention Policy
MEDIA_RETENTION_ENABLED=true
MEDIA_RETENTION_DAYS=30
MEDIA_VIEW_DEBOUNCE_HOURS=6
